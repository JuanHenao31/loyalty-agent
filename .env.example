 # === App ===
APP_NAME=Apoli · Techapoli Loyalty
DEBUG=false
API_HOST=0.0.0.0
API_PORT=9000
CORS_ORIGINS=

# === LLM (OpenAI) ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2

# === Loyalty core ===
LOYALTY_API_BASE_URL=http://localhost:8000
LOYALTY_API_TIMEOUT_SECONDS=15
# Service account (platform_admin or business_owner) used for read-only tools
LOYALTY_AGENT_SERVICE_EMAIL=
LOYALTY_AGENT_SERVICE_PASSWORD=
LOYALTY_TOKEN_CACHE_TTL_SECONDS=1500

# === Postgres (agent memory + auditoría) ===
AGENT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/loyalty_agent
# 32-byte base64 Fernet key. Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
REFRESH_TOKEN_ENCRYPTION_KEY=

# === Telegram ===
TELEGRAM_BOT_TOKEN=
# Shared secret sent by Telegram in X-Telegram-Bot-Api-Secret-Token header (set via setWebhook)
TELEGRAM_WEBHOOK_SECRET=

# === WhatsApp Cloud API ===
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Used to validate X-Hub-Signature-256 on inbound webhooks
WHATSAPP_APP_SECRET=
WHATSAPP_GRAPH_VERSION=v21.0

# === Agent runtime ===
AGENT_MEMORY_TTL_HOURS=168
AGENT_MAX_TOOL_ITERATIONS=8
CONFIRMATION_EXPIRY_MINUTES=10
